<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>">

